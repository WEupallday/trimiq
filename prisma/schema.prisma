// TrimIQ database schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  plan         String   @default("free")
  editsUsed    Int      @default(0)
  createdAt    DateTime @default(now())
}
